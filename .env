# ⚠️  VULN: Security Misconfiguration — secrets hardcodés en clair dans .env commité
# CWE-798 / OWASP A05:2021

# Clé JWT faible et prévisible
JWT_SECRET=secret123

# Base de données en clair
DATABASE_PATH=./data/tickets.db

# Mode debug activé en production
DEBUG=true
NODE_ENV=development

# Clé admin par défaut
ADMIN_PASSWORD=admin123

# URL interne exposée (utile pour tester SSRF)
INTERNAL_API=http://169.254.169.254
